# Client SDK config (safe to expose — these are public identifiers)
# Fill these in from the fudur-18485 Firebase project settings.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fudur-18485.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fudur-18485
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fudur-18485.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Admin SDK service account (server-only — never expose to the client).
# Generate at: Firebase console > Project settings > Service accounts > Generate new private key.
FIREBASE_ADMIN_PROJECT_ID=fudur-18485
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
